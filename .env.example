# ============================================================
# AI INVESTMENT FUND — Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# --- PRIMARY LLM: Google Gemini 1.5 Flash (FREE TIER) ---
# Free: 15 requests/min, 1M tokens/day — get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- FALLBACK LLM: Anthropic Claude Haiku (pay-per-use) ---
# Pay only for what you use, no subscription — get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- FINANCIAL DATA SOURCES ---
# Financial Modeling Prep (FMP) - FREE: 250 calls/day
# Get key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# Alpha Vantage - FREE: 25 calls/day (good for cross-validation)
# Get key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# --- OPTIONAL: Better news search ---
# Get your key at: https://serper.dev (free plan: 2500 searches/month)
SERPER_API_KEY=your_serper_api_key_here

# --- Investment Settings ---
# Initial simulated capital in USD
INITIAL_CAPITAL=10000
# Risk level: conservative / moderate / aggressive
RISK_LEVEL=moderate
# Max % of portfolio per single stock
MAX_POSITION_SIZE=0.10
# Minimum margin of safety required (Buffett principle)
MIN_MARGIN_OF_SAFETY=0.30
